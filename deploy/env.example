# Copy to .env on the VPS (e.g. /opt/autopublish-drive/.env). Do not commit real values.

# Google Drive — service account JSON path (folder Auto_Publish shared with SA email as Viewer).
GOOGLE_SERVICE_ACCOUNT_FILE=/opt/autopublish-drive/secrets/google-sa.json

# Folder containing videos to auto-publish.
DRIVE_FOLDER_ID=your_drive_folder_id_here

# Modal autopublish endpoint (your modal.run URL, no trailing slash required).
MODAL_AUTOPUBLISH_URL=https://YOUR-WORKSPACE--replix-autopublish-autopublish.modal.run

# Same secret as Modal Secret "api-auth-token" / API_AUTH_TOKEN used by the endpoint Bearer check.
API_AUTH_TOKEN=

# Optional: Telegram alerts from the poller itself (failures before/during Modal).
# Both must be set or alerts are silently skipped (logs still go to stderr/journal).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: state file (processed Google file IDs). Default: ~/.autopublish-drive/processed.json
# AUTOPUBLISH_STATE_FILE=/opt/autopublish-drive/state/processed.json

# Optional: append logs here in addition to journald.
# LOG_FILE=/var/log/autopublish-drive.log
